#!/usr/bin/env bash
set -euo pipefail

sudo systemctl disable --now max98390-hda-i2c-setup.service || true
sudo systemctl disable --now max98390-hda-check-upstream.service || true

sudo mv /etc/modules-load.d/max98390-hda.conf /etc/modules-load.d/max98390-hda.conf.disabled 2>/dev/null || true

sudo tee /etc/modprobe.d/max98390-hda-off.conf >/dev/null <<'MODPROBE'
blacklist snd_hda_scodec_max98390
blacklist snd_hda_scodec_max98390_i2c
MODPROBE

sudo modprobe -r snd_hda_scodec_max98390_i2c snd_hda_scodec_max98390 || true
systemctl --user restart wireplumber pipewire pipewire-pulse || true

echo "speakers OFF"
