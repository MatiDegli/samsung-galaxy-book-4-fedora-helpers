#!/usr/bin/env bash
set -euo pipefail

sudo rm -f /etc/modprobe.d/max98390-hda-off.conf

sudo mv /etc/modules-load.d/max98390-hda.conf.disabled /etc/modules-load.d/max98390-hda.conf 2>/dev/null || true

sudo modprobe snd_hda_scodec_max98390
sudo modprobe snd_hda_scodec_max98390_i2c

sudo systemctl enable --now max98390-hda-i2c-setup.service
sudo systemctl enable --now max98390-hda-check-upstream.service

systemctl --user restart wireplumber pipewire pipewire-pulse || true

echo "speakers ON"
